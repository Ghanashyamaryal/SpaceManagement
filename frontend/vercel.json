{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://space-management-system-w2i3.onrender.com/api/:path*"
    },
    {
      "source": "/public/:path*",
      "destination": "https://space-management-system-w2i3.onrender.com/public/:path*"
    },
    {
      "source": "/((?!api|public|assets|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
